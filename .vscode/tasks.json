{
 "version": "2.0.0",
 "tasks": [
  {
   "type": "cppbuild",
   "label": "build",
   "command": "C:\\mingw64\\bin\\g++.exe",
   "args": [
    "-fopenmp",
    "-std=c++17",
    "-O2",
    "-static-libgcc",
    "-static-libstdc++",
    "${workspaceFolder}/src/main.cpp",
    "${workspaceFolder}/src/Agent.cpp",
    "${workspaceFolder}/src/Simulation.cpp",
    "${workspaceFolder}/src/Graphics.cpp",
    "-I${workspaceFolder}/include",
    "-IC:\\SFML-3.0.2-Windows.MinGW.x64\\SFML-3.0.2\\include",
    "-LC:\\SFML-3.0.2-Windows.MinGW.x64\\SFML-3.0.2\\lib",
    "-lsfml-graphics",
    "-lsfml-window",
    "-lsfml-system",
    "-o",
    "${workspaceFolder}/MassMadness.exe"
   ],
   "options": {
    "cwd": "${workspaceFolder}"
   },
   "problemMatcher": ["$gcc"],
   "group": {
    "kind": "build",
    "isDefault": true
   }
  }
 ]
}